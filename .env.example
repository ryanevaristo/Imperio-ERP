# =============================================================================
# Alicerce — Pulsari Analytics — Variáveis de Ambiente
# =============================================================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores reais no .env
# 3. NUNCA commite o .env — ele já está no .gitignore
#
# Gerar SECRET_KEY:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# =============================================================================

# ── Segurança ─────────────────────────────────────────────────────────────────
SECRET_KEY=substitua-por-uma-chave-longa-e-aleatoria-gerada-com-o-comando-acima
DEBUG=False
# Em produção: seu domínio real. Em dev: localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1,seudominio.com.br
CSRF_TRUSTED_ORIGINS=https://seudominio.com.br

# ── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_NAME=alicerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=allicerce123
# Docker local: host.docker.internal | VPS/produção: localhost ou IP interno
DB_HOST=host.docker.internal
DB_PORT=5432

# ── E-mail ────────────────────────────────────────────────────────────────────
# Dev: remova EMAIL_BACKEND (usa console por padrão — imprime no terminal)
# Produção: descomente e configure
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu@gmail.com
# Gmail: use App Password (não a senha normal)
# Gerar em: https://myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=sua_app_password_aqui
DEFAULT_FROM_EMAIL=Alicerce by Pulsari <noreply@pulsarianalytics.com.br>

# ── Cloudflare R2 (armazenamento de arquivos) ─────────────────────────────────
# Deixe R2_BUCKET_NAME em branco para usar armazenamento local (dev)
# Produção: preencha todas as variáveis abaixo
#
# Como obter as credenciais:
#   1. Acesse dash.cloudflare.com → R2 Object Storage → Create bucket
#   2. Crie um bucket (ex: alicerce-media)
#   3. Vá em Manage R2 API Tokens → Create API Token
#      - Permissões: Object Read & Write
#      - Escopo: Bucket específico
#   4. Copie Account ID em: dash.cloudflare.com → lado direito da página R2
#
R2_BUCKET_NAME=alicerce-media
R2_ACCOUNT_ID=51cd3232942c65576e7ff9bc213fcf28
R2_ACCESS_KEY_ID=401238a4728031c4776c8fea6834984e
R2_SECRET_ACCESS_KEY=73f51980089ea4f3e6a36ad8c4ae270e49167afa7fb572c1effe2b48724d7725

# Opcional: domínio personalizado para os arquivos (ex: files.alicerce.com.br)
# Se deixar vazio, usa o endpoint R2 diretamente
R2_CUSTOM_DOMAIN=
